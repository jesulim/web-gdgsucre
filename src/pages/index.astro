---
import About from "@/components/events/bwai-26/About.astro"
import Countdown from "@/components/events/bwai-26/Countdown.astro"
import Footer from "@/components/events/bwai-26/Footer.astro"
import Header from "@/components/events/bwai-26/Header.astro"
import Hero from "@/components/events/bwai-26/Hero.astro"
import Info from "@/components/events/bwai-26/Info.astro"
import BaseLayout from "@/layout/BaseLayout.astro"

// === HERO desktop (HeroAntiguo.astro) ===
const imgHeroBlob = "/assets/figma/b9c79608a384972a5a69e904ce221f638866b56c.svg" // blob bottom
const imgHeroBracketR = "/assets/figma/c16da647df00ff46b018e2f0a32b2954771e2ba6.svg" // bracket right rotate-135
const imgHeroCrossL = "/assets/figma/bb9d3b1aa18f4c8c9f5da82369e9a61bb65de042.svg" // cross left-mid -rotate-30
const imgHeroCross = "/assets/figma/f0498913075e3a627c6501a3f88710affa1587e4.svg" // cross (top-left + bottom-right) -rotate-15
const imgHeroBracketL = "/assets/figma/062060ef03ed1a1b0bf212f66385ddc68d0fed28.svg" // bracket left-bottom rotate-180
const imgHeroStar = "/assets/figma/d4be59c59d8e565974d7b1222bc609199519a479.svg" // star top-right

// === INFO desktop ===
const imgInfoDiag = "/assets/figma/142b29fa59e70aeddf0a30daa8a49cb9db01d572.svg" // diagonal deco
const imgInfoBlob = "/assets/figma/b9c79608a384972a5a69e904ce221f638866b56c.svg" // blob bottom-left (mismo que hero)

// === INFO mobile ===
const imgInfoBracket = "/assets/figma/9394006c410457442a23560b3cf1b58ac83b2b60.svg" // bracket deco

// === COUNTDOWN mobile ===
const imgCdHalfMoon = "/assets/figma/bf6b94039f61e4e47a8a9922b3633c82caef3b20.svg" // half-moon

// === ABOUT desktop ===
const imgAboutHalfCircle = "/assets/figma/fcd5150aa2ac855184e8a6d71bdd10b930969d2e.svg" // half-circle left rotate-180
const imgAboutHash = "/assets/figma/a93824e103e6a596e9dda2b02293cce404ba1e07.svg" // hash top-right

// === ABOUT mobile ===
const imgAboutBgBlob = "/assets/figma/4a8c1bc73ab130631741be4081024414dcb8e378.svg" // blob bottom-right
const imgAboutBgHash = "/assets/figma/cb17e49d3a8f1a50a9132d08865c3a01d9d55797.svg" // hash top-right

const HEADER = 69
const HERO_TOP = HEADER
const INFO_TOP = HERO_TOP + 1024
const ABOUT_TOP = INFO_TOP + 1024
---

<BaseLayout
  theme="light"
  title="Build With AI Sucre 2026"
  description="Build with AI es la serie global de Google Developer Groups donde developers, estudiantes y curiosos nos juntamos para aprender IA en modo hands-on."
>
  <div class="w-full min-h-screen font-sans overflow-x-hidden relative bg-white">

    <!-- ===== CAPA DE FONDO GLOBAL ===== -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">

      <!-- ============ HERO DESKTOP ============ -->

      <!-- blob bottom (hipot resuelto: ~401×400px) -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 535px; top: ${HERO_TOP + 770}px; width: 491px; height: 490px;`}>
        <div class="flex-none" style="transform: rotate(15deg); width: 401px; height: 400px;">
          <div class="relative size-full">
            <div class="absolute" style="inset: -3.12%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroBlob} />
            </div>
          </div>
        </div>
      </div>

      <!-- bracket derecho rotate-135 -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 1230px; top: ${HERO_TOP + 462}px; width: 154px; height: 154px;`}>
        <div class="flex-none rotate-135">
          <div class="relative" style="height: 57px; width: 161px;">
            <div class="absolute" style="inset: -21.92% -7.77%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroBracketR} />
            </div>
          </div>
        </div>
      </div>

      <!-- cross izquierda-medio -rotate-30 -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 50px; top: ${HERO_TOP + 433}px; width: 163px; height: 163px;`}>
        <div class="flex-none -rotate-30">
          <div class="relative" style="height: 118px; width: 121px;">
            <div class="absolute" style="inset: -10.57% -10.37%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroCrossL} />
            </div>
          </div>
        </div>
      </div>

      <!-- cross top-left -rotate-15 -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: -47px; top: ${HERO_TOP + 76}px; width: 214px; height: 214px;`}>
        <div class="flex-none -rotate-15">
          <div class="relative" style="width: 175px; height: 175px;">
            <div class="absolute" style="inset: -7.14%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroCross} />
            </div>
          </div>
        </div>
      </div>

      <!-- cross bottom-right -rotate-15 -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 1270px; top: ${HERO_TOP + 789}px; width: 214px; height: 214px;`}>
        <div class="flex-none -rotate-15">
          <div class="relative" style="width: 175px; height: 175px;">
            <div class="absolute" style="inset: -7.14%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroCross} />
            </div>
          </div>
        </div>
      </div>

      <!-- bracket izquierda-bottom rotate-180 -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 0; top: ${HERO_TOP + 760}px; width: 173px; height: 350px;`}>
        <div class="flex-none rotate-180">
          <div class="relative" style="width: 173px; height: 350px;">
            <div class="absolute" style="inset: -3.57% -7.23%;">
              <img alt="" class="block max-w-none size-full" src={imgHeroBracketL} />
            </div>
          </div>
        </div>
      </div>

      <!-- star top-right -->
      <div class="hidden md:block absolute"
        style={`left: 1177px; top: ${HERO_TOP + 33}px; width: 187px; height: 187px;`}>
        <div class="absolute" style="inset: -6.68%;">
          <img alt="" class="block max-w-none size-full" src={imgHeroStar} />
        </div>
      </div>

      <!-- ============ INFO DESKTOP ============ -->

      <!-- diagonal deco (left: 756px, top: -141px relativo a Info) -->
      <div class="hidden md:block absolute overflow-hidden"
        style={`left: 756px; top: ${INFO_TOP - 142}px; width: 1136px; height: 1136px;`}>
        <div class="flex items-center justify-center w-full h-full" style="transform: rotate(45deg);">
          <div class="relative" style="width: 531px; height: 1076px;">
            <div class="absolute" style="inset: -1.16% -2.35%;">
              <img alt="" class="block max-w-none size-full" src={imgInfoDiag} />
            </div>
          </div>
        </div>
      </div>

      <!-- blob bottom-left de Info (hipot resuelto igual que hero blob) -->
      <div class="hidden md:flex absolute items-center justify-center"
        style={`left: 535px; top: ${INFO_TOP + 770}px; width: 491px; height: 490px;`}>
        <div class="flex-none" style="transform: rotate(15deg); width: 401px; height: 400px;">
          <div class="relative size-full">
            <div class="absolute" style="inset: -3.12%;">
              <img alt="" class="block max-w-none size-full" src={imgInfoBlob} />
            </div>
          </div>
        </div>
      </div>

      <!-- ============ ABOUT DESKTOP ============ -->

      <!-- half-circle bottom-left rotate-180 -->
      <div class="hidden md:block absolute"
        style={`left: -75px; top: ${ABOUT_TOP + 695}px; width: 346px; height: 702px;`}>
        <div class="flex-none rotate-180" style="width: 346px; height: 702px;">
          <div class="relative w-full h-full">
            <div class="absolute" style="inset: -1.78% -3.61%;">
              <img alt="" class="block max-w-none size-full" src={imgAboutHalfCircle} />
            </div>
          </div>
        </div>
      </div>

      <!-- hash top-right de About -->
      <div class="hidden md:block absolute"
        style={`left: ${ABOUT_TOP !== null ? 896 : 896}px; top: ${ABOUT_TOP + 150}px; width: 653px; height: 878px;`}>
        <div class="absolute" style="inset: -1.95% -1.91%;">
          <img alt="" class="block max-w-none size-full" src={imgAboutHash} />
        </div>
      </div>

    </div>

    <Header />
    <main class="overflow-x-hidden">
      <Hero />
      <Info />
      <Countdown />
      <About />
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  html, body {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }
</style>